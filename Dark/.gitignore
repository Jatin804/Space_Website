# 🚫 .gitignore (Django + MySQL + Python)

```gitignore
# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
*$py.class

# Virtual Environment
venv/
env/
ENV/
.venv/

# -----------------------------
# Django
# -----------------------------
*.log
*.pot
*.pyc
db.sqlite3
db.sqlite3-journal

# Django media/static (optional depending on setup)
media/
staticfiles/

# -----------------------------
# Environment Variables
# -----------------------------
.env
.env.*

# -----------------------------
# MySQL / Database
# -----------------------------
*.sql
*.db

# -----------------------------
# VS Code / IDEs
# -----------------------------
.vscode/
.idea/
*.swp
*.swo

# -----------------------------
# OS Files
# -----------------------------
.DS_Store
Thumbs.db

# -----------------------------
# Node (if frontend tooling used)
# -----------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------
# Build / Distribution
# -----------------------------
build/
dist/
*.egg-info/
.eggs/

# -----------------------------
# Testing / Coverage
# -----------------------------
.coverage
htmlcov/
.pytest_cache/

# -----------------------------
# Misc
# -----------------------------
*.bak
*.tmp
```
